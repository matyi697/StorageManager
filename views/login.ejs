<!DOCTYPE html>
<html lang="hu">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pipetta Center - Bejelentkezés</title>
    <style>
        :root {
            --primary: #2c3e50;
            --accent: #007bff;
            --error: #e74c3c;
            --bg: #f0f2f5;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background: var(--bg);
            background: linear-gradient(135deg, #f0f2f5 0%, #a3b3c6 100%);        }

        .login-card {
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            text-align: center;
            width: 100%;
            max-width: 350px;
            border-top: 5px solid var(--accent);
        }

        .nav-logo {
            /* Alapméretek és illeszkedés */
            height: 35px;
            width: auto;
            object-fit: contain;

            background-color: #3368c6; 
            padding: 10px;           
            border-radius: 10px;      

            box-shadow: 0 2px 5px rgba(0,0,0,0.1); 

            vertical-align: middle;
        }

        .logo-area {
            font-size: 50px;
            margin-bottom: 10px;
        }

        h2 {
            color: var(--primary);
            margin-bottom: 5px;
            font-size: 24px;
        }

        p {
            color: #666;
            font-size: 14px;
            margin-bottom: 30px;
        }

        .input-group {
            text-align: left;
            margin-bottom: 20px;
        }

        .input-group label {
            display: block;
            font-size: 12px;
            font-weight: bold;
            color: var(--primary);
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        input {
            display: block;
            width: 100%;
            padding: 12px 15px;
            box-sizing: border-box;
            border: 2px solid #ddd;
            border-radius: 6px;
            font-size: 16px;
            transition: border-color 0.3s;
            outline: none;
        }

        input:focus {
            border-color: var(--accent);
        }

        button {
            width: 100%;
            padding: 14px;
            background: var(--accent);
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            font-size: 16px;
            transition: background 0.3s, transform 0.2s;
            margin-top: 10px;
        }

        button:hover {
            background: #0056b3;
        }

        button:active {
            transform: scale(0.98);
        }

        .error-box {
            background: #fdeaea;
            color: var(--error);
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 20px;
            font-size: 14px;
            border: 1px solid #f5c2c2;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .footer-text {
            margin-top: 30px;
            font-size: 11px;
            color: #999;
        }
    </style>
</head>

<body>
    <div class="login-card">
        <div class="logo-area">
            <img src="https://fejlesztes.pipettacenter.hu/wp-content/uploads/2025/06/PIPETTA-CENTER-LOGO-7.png" alt="Logo" class="nav-logo">

        </div>
        
        <h2>Irányítópult</h2>
        <p>Kérjük, jelentkezzen be a folytatáshoz!</p>

        <% if (error) { %>
            <div class="error-box">
                <span>⚠️</span>
                <%= error %>
            </div>
            <% } %>

                <form action="/login" method="POST">
                    <div class="input-group">
                        <label>Felhasználónév</label>
                        <input type="text" name="username" placeholder="Felhasználónév" required autofocus>
                    </div>

                    <div class="input-group">
                        <label>Jelszó</label>
                        <input type="password" name="password" placeholder="••••••••" required>
                    </div>

                    <button type="submit">Belépés a Raktárkezelőbe</button>
                </form>

                <div class="footer-text">
                    Wittmann Mátyás @ 2026
                </div>
    </div>
</body>

</html>