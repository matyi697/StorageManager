<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <title>Leltár Sikeres</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; margin: 0; padding: 0; }
        .container { max-width: 700px; margin: 60px auto; text-align: center; }
        .card { background: white; border-radius: 12px; padding: 40px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
        .icon { font-size: 60px; margin-bottom: 20px; }
        h1 { color: #28a745; margin-bottom: 10px; }
        .summary { font-size: 18px; color: #555; margin-bottom: 30px; }
        
        .new-parts-box { background: #fff3cd; border: 1px solid #ffeeba; border-radius: 8px; padding: 20px; text-align: left; margin-bottom: 30px; }
        .new-parts-box h3 { color: #856404; margin-top: 0; font-size: 16px; }
        .new-parts-list { list-style: none; padding: 0; margin: 0; }
        .new-parts-list li { padding: 10px; border-bottom: 1px solid #ffeeba; display: flex; justify-content: space-between; align-items: center; }
        .new-parts-list li:last-child { border-bottom: none; }
        .btn-edit-small { background: #ffc107; color: #212529; text-decoration: none; padding: 6px 12px; border-radius: 4px; font-size: 12px; font-weight: bold; }
        
        .btn-primary { background: #007bff; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 16px; }
    </style>
</head>
<body>

    <div class="container">
        <div class="card">
            <div class="icon">✅</div>
            <h1>Leltár sikeresen elmentve!</h1>
            
            <p class="summary">
                <strong><%= updatedCount %></strong> db meglévő alkatrész készlete frissítve lett.
            </p>

            <% if (newParts.length > 0) { %>
                <div class="new-parts-box">
                    <h3>⚠️ Figyelem: Új alkatrészek lettek bevezetve!</h3>
                    <p style="font-size: 13px; color: #666; margin-bottom: 15px;">
                        Ezek az alkatrészek még nem szerepeltek a rendszerben. Generáltunk nekik egy ideiglenes gyári számot. Kérjük, kattints a szerkesztés gombra, és pótold a hiányzó adatokat (Ár, Gyári szám, Raktári pozíció)!
                    </p>
                    <ul class="new-parts-list">
                        <% newParts.forEach(function(part) { %>
                            <li>
                                <span><strong><%= part.name %></strong> (+<%= part.qty %> db)</span>
                                <a href="/edit-part/<%= part.id %>" class="btn-edit-small">✏️ Adatok pótlása</a>
                            </li>
                        <% }); %>
                    </ul>
                </div>
            <% } %>

            <a href="/dashboard" class="btn-primary">Vissza az irányítópultra</a>
        </div>
    </div>
</body>
</html>